{
  "name": "fetch-the-standard-news",
  "author": "Theerut Top",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=25.8.2 <26"
  },
  "packageManager": "pnpm@9.15.0",
  "homepage": "https://topkoong.github.io/fetch-the-standard-news",
  "keywords": [
    "preact",
    "vite",
    "typescript",
    "ghactions",
    "vitest",
    "eslint",
    "prettier",
    "husky",
    "tailwindcss"
  ],
  "scripts": {
    "prepare": "husky",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint:fix": "eslint ./src --ext .jsx,.js,.ts,.tsx --fix --ignore-pattern \"**/*.d.ts\"",
    "lint:format": "prettier --loglevel warn --write \"./**/*.{js,jsx,ts,tsx,css,md,json}\" ",
    "lint": "pnpm run lint:format && pnpm run lint:fix",
    "type-check": "tsc"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/topkoong/fetch-the-standard-news.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/topkoong/fetch-the-standard-news/issues"
  },
  "dependencies": {
    "preact": "10.29.0",
    "react-query": "3.39.3",
    "react-router-dom": "7.13.2"
  },
  "devDependencies": {
    "@preact/preset-vite": "2.10.5",
    "@tailwindcss/vite": "4.2.2",
    "@typescript-eslint/eslint-plugin": "8.57.2",
    "@typescript-eslint/parser": "8.57.2",
    "axios": "1.13.6",
    "eslint": "10.1.0",
    "eslint-config-preact": "2.0.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "vite": "8.0.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,css,md,json}": [
      "prettier --loglevel warn --write"
    ],
    "*.{ts,tsx}": "eslint --fix --quiet"
  }
}
